rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'hashhash4uhell@gmail.com';
    }

    match /accounts/{accountId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
